{
	"name": "discord-bot-framework",
	"version": "1.0.0",
	"description": "Modular Discord Bot Framework",
	"main": "dist/index.js",
	"scripts": {
		"build": "tsc",
		"dev": "cross-env NODE_ENV=development ts-node -r tsconfig-paths/register src/index.ts",
		"start": "cross-env NODE_ENV=production node dist/index.js",
		"db:migrate": "ts-node src/database/migrate.ts",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write ."
	},
	"dependencies": {
		"discord.js": "^14.14.1",
		"dotenv": "^16.3.1",
		"pg": "^8.11.3",
		"winston": "^3.19.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.14",
		"@types/node": "^20.10.0",
		"@types/pg": "^8.10.9",
		"cross-env": "^10.1.0",
		"ts-node": "^10.9.2",
		"tsconfig-paths": "^4.2.0",
		"typescript": "^5.3.2"
	}
}
