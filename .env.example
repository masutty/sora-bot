NODE_ENV=development

## PostgreSQL
DATABASE_URL=postgresql://postgres:admin@localhost:5432/yourdatabase
# Set to "true" only for managed Postgres that requires SSL (Heroku, RDS, Supabase, etc).
# Leave unset/false for local/self-hosted Postgres, including the bundled docker-compose service.
DATABASE_SSL=false

## Docker (docker-compose only) - overrides DATABASE_URL's credentials/db name for the bundled
## postgres service; irrelevant if you're not using docker-compose or point at an external DB.
# POSTGRES_DB=botdb
# POSTGRES_PASSWORD=postgres

## Bot
OWNER_IDS=188851299255713792
DEFAULT_PREFIX=!
# used for generating return messages to the user. controls the "joke" level
# range from 0 (serious, straightforward) to 3 (jokiest, might be slighly hard to understand via message alone)
DEFAULT_QUIP_JOKE_LEVEL=0

## Logging
LOG_LEVEL=debug

## Others
ENCRYPTION_KEY="somerandomvaluetouseasencryptionkey"

# Discord
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_client_id_here






































