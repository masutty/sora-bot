NODE_ENV=development

## PostgreSQL
DATABASE_URL=postgresql://postgres:admin@localhost:5432/yourdatabase
# Set to "true" only for managed Postgres that requires SSL (Heroku, RDS, Supabase, etc).
# Leave unset/false for local/self-hosted Postgres, including the bundled docker-compose service.
DATABASE_SSL=false

## Docker (docker-compose only) - overrides DATABASE_URL's credentials/db name for the bundled
## postgres service; irrelevant if you're not using docker-compose or point at an external DB.
# POSTGRES_DB=botdb
# POSTGRES_PASSWORD=postgres

## Bot
OWNER_IDS=188851299255713792
DEFAULT_PREFIX=!
# used for generating return messages to the user. controls the "joke" level
# range from 0 (serious, straightforward) to 3 (jokiest, might be slighly hard to understand via message alone)
DEFAULT_QUIP_JOKE_LEVEL=0

## Logging
# Levels, least to most detail: error, warn, info, debug, verbose ("verbose" is the noisiest -
# macro/biome parsing traces live there, below "debug").
# LOG_LEVEL controls what's captured to logs/combined-*.log.
LOG_LEVEL=verbose
# CONSOLE_LOG_LEVEL controls what's printed to the console/terminal - kept quieter by default so
# parsing noise doesn't clutter it; set to "verbose" too if you need to see it live.
CONSOLE_LOG_LEVEL=debug
# How many days of logs/combined-*.log and logs/error-*.log to keep before old ones are deleted.
LOG_RETENTION_DAYS=14
# Optional: also rotate a file early if it passes this size (e.g. "20m"), regardless of date.
# Leave unset for date-based rotation only.
# LOG_MAX_SIZE=20m

## Others
ENCRYPTION_KEY="somerandomvaluetouseasencryptionkey"

# Discord
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_client_id_here






































